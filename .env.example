NODE_ENV=
PORT=

# Used to sign auth session tokens. Use a long random value in real environments.
AUTH_SECRET=replace-with-a-long-random-secret

POSTGRES_DB=clothcast
POSTGRES_USER=clothcast
POSTGRES_PASSWORD=clothcast_password

# Use this from the host machine when running Prisma locally.
DATABASE_URL=postgresql://clothcast:clothcast_password@localhost:5432/clothcast?schema=public

# Use this inside Docker containers on the compose network.
DOCKER_DATABASE_URL=postgresql://clothcast:clothcast_password@db:5432/clothcast?schema=public

# S3 bucket used for clothes image uploads.
AWS_REGION=ap-northeast-2
AWS_ACCESS_KEY_ID=replace-with-access-key
AWS_SECRET_ACCESS_KEY=replace-with-secret-key
AWS_S3_BUCKET_NAME=replace-with-bucket-name

# Optional. Use this when serving images through CloudFront or a custom public bucket URL.
AWS_S3_PUBLIC_BASE_URL=

# OpenWeather API key used by the server-side weather API.
OPENWEATHER_API_KEY=replace-with-openweather-api-key

# Gemini API key used by the server-side recommendation API.
GEMINI_API_KEY=replace-with-gemini-api-key

# Optional. Defaults to gemini-2.5-flash when omitted.
GEMINI_MODEL=gemini-2.5-flash
