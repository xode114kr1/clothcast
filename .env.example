NODE_ENV=
PORT=

POSTGRES_DB=clothcast
POSTGRES_USER=clothcast
POSTGRES_PASSWORD=clothcast_password

# Use this from the host machine when running Prisma locally.
DATABASE_URL=postgresql://clothcast:clothcast_password@localhost:5432/clothcast?schema=public

# Use this inside Docker containers on the compose network.
DOCKER_DATABASE_URL=postgresql://clothcast:clothcast_password@db:5432/clothcast?schema=public
